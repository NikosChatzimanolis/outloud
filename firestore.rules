rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuth() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return request.auth.uid == uid;
    }
    match /users/{uid} {
      // Read: any authenticated user (needed for username lookup and showing names in threads)
      allow read: if isAuth();
      // Write: only the owner (create/update own profile)
      allow write: if isAuth() && isOwner(uid);
    }
    match /relationships/{relId} {
      allow read: if isAuth() && (resource.data.userA == request.auth.uid || resource.data.userB == request.auth.uid);
      allow create: if isAuth() && (request.resource.data.userA == request.auth.uid || request.resource.data.userB == request.auth.uid);
      allow update: if isAuth() && (resource.data.userA == request.auth.uid || resource.data.userB == request.auth.uid);
    }
    match /threads/{threadId} {
      allow read: if isAuth() && request.auth.uid in resource.data.participants;
      allow create: if isAuth() && request.auth.uid in request.resource.data.participants;
      allow update, delete: if isAuth() && request.auth.uid in resource.data.participants;
      match /messages/{messageId} {
        allow read: if isAuth();
        allow create: if isAuth() && request.resource.data.fromUid == request.auth.uid;
        allow update: if isAuth();
      }
    }
    match /reports/{reportId} {
      allow create: if isAuth();
      allow read: if false;
    }
  }
}
